* text=auto eol=lf

# Keep Windows scripts with CRLF where appropriate
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Generated Windows runner sources can keep CRLF
windows/** text eol=crlf

# Binary assets — MUST override the broad rules above so git never applies
# text/EOL conversion (CRLF normalization corrupts binaries like .ico).
# 이 규칙들이 위의 'windows/** text eol=crlf'보다 나중에 와서 우선합니다.
*.ico binary -eol
*.png binary -eol
*.jpg binary -eol
*.jpeg binary -eol
*.gif binary -eol
*.ttf binary -eol
*.otf binary -eol
*.msix binary -eol
*.exe binary -eol
*.dll binary -eol
*.so binary -eol
*.pfx binary -eol
*.cer binary -eol
*.zip binary -eol

